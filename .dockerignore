# Exclude mount points and runtime directories
**/nas-mount-*
**/test-smb-mount*
**/nas-storage*

# Exclude build artifacts
**/nas-emu-fuse
!src/fuse-driver/nas-emu-fuse
**/obj/
**/*.o
**/*.so

# Exclude Git and IDE files
.git/
.gitignore
**/.DS_Store
**/.vscode/
**/.idea/

# Exclude logs and temporary files
**/*.log
**/tmp/
**/temp/

# Exclude documentation (not needed for build)
**/*.md
**/README*

# Exclude Python orchestration (not needed in any Docker image)
nas_sim/
Dockerfile.test
pyproject.toml
VERSION
__pycache__/
*.egg-info/
.venv/

# Include only source code and essential config files
!src/
