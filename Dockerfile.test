# Test-runner container for NAS Fault Simulator
# Mounts SMB from target container, runs pytest
FROM ubuntu:22.04

RUN apt-get update && apt-get install -y \
    cifs-utils \
    smbclient \
    python3 \
    python3-pip \
    && rm -rf /var/lib/apt/lists/*

RUN pip3 install --no-cache-dir pytest

WORKDIR /app

# Copy test code
COPY tests/ /app/tests/

# Copy test configs for reference
COPY src/fuse-driver/tests/configs/ /configs/

# Environment defaults (overridden at runtime)
ENV SMB_HOST=target \
    SMB_PORT=445 \
    SMB_SHARE=nasshare \
    SMB_USERNAME=nasusr \
    SMB_PASSWORD=naspass \
    SMB_MOUNT=/mnt/smb \
    RAW_STORAGE=/var/nas-storage \
    TEST_CONFIG=""

RUN mkdir -p /mnt/smb

ENTRYPOINT ["pytest"]
CMD ["-v", "--tb=short", "tests/"]
